<Window x:Class="TaskManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManager.App"
        xmlns:viewmodels="clr-namespace:TaskManager.App.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="DEV MGR [Y2K]" Height="700" Width="1000"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <!-- Base Grid for allowing transparency dropshadow effect if needed. DeepBlackBackground -->
    <Grid Background="{StaticResource DeepBlackBrush}">
        <!-- Border for the whole Window -->
        <Border BorderBrush="{StaticResource DarkChromeBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <!-- Titlebar -->
                    <RowDefinition Height="*" />
                    <!-- Content -->
                    <RowDefinition Height="30" />
                    <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Titlebar Area -->
                <Grid Grid.Row="0" Background="{StaticResource GraphiteBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                        <!-- Icon representation using text bracket -->
                        <TextBlock Text="[>]" Foreground="{StaticResource ChromeHighlightBrush}" FontWeight="Bold" Margin="0,0,10,0" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="DEV MGR | PORT &amp; DOCKER CONTROL" FontWeight="Bold" Foreground="{StaticResource PureWhiteBrush}" FontSize="16"/>
                        <TextBlock Text=" [SYSTEM O.S.]" Foreground="{StaticResource ChromeHighlightBrush}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="-" Style="{StaticResource Y2KButton}" Width="40" Padding="0" Click="MinimizeButton_Click" Background="Transparent" BorderThickness="0" Foreground="{StaticResource ChromeHighlightBrush}" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="O" Style="{StaticResource Y2KButton}" Width="40" Padding="0" Click="MaximizeButton_Click" Background="Transparent" BorderThickness="0" Foreground="{StaticResource ChromeHighlightBrush}" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="X" Style="{StaticResource Y2KButton}" Width="40" Padding="0" Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Foreground="#FF3333" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                    
                    <Border BorderBrush="{StaticResource MetallicGreyBrush}" BorderThickness="0,0,0,1" Grid.ColumnSpan="2"/>
                </Grid>

                <!-- Background Image (shadow.png) behind Glass -->
                <Image Grid.Row="1" Source="pack://application:,,,/Assets/shadow.png" Stretch="UniformToFill" VerticalAlignment="Top" Margin="0,-350,0,0" Opacity="0.1"/>

                <!-- Main Content Area with Glass Panel -->
                <Border Grid.Row="1" Style="{StaticResource Y2KGlassPanel}" Margin="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <!-- Sidebar -->
                            <ColumnDefinition Width="1" />
                            <!-- Splitter -->
                            <ColumnDefinition Width="*" />
                            <!-- Main View -->
                        </Grid.ColumnDefinitions>

                        <!-- Sidebar -->
                        <StackPanel Grid.Column="0" Margin="10">
                            <Button Content="> SYSTEM" Command="{Binding LoadSystemViewCommand}" Style="{StaticResource Y2KButton}" Margin="0,0,0,10" HorizontalContentAlignment="Left" Foreground="{Binding IsSystemViewVisible, Converter={x:Static local:Converters.ActiveForegroundConverter}}"/>
                            <Button Content="> PORTS" Command="{Binding LoadPortsViewCommand}" Style="{StaticResource Y2KButton}" Margin="0,0,0,10" HorizontalContentAlignment="Left" Foreground="{Binding IsPortsViewVisible, Converter={x:Static local:Converters.ActiveForegroundConverter}}"/>
                            <Button Content="> DOCKER" Command="{Binding LoadDockerViewCommand}" Style="{StaticResource Y2KButton}" Margin="0,0,0,10" HorizontalContentAlignment="Left" Foreground="{Binding IsDockerViewVisible, Converter={x:Static local:Converters.ActiveForegroundConverter}}"/>
                            <Button Content="> REFRESH" Command="{Binding RefreshCurrentViewCommand}" Style="{StaticResource Y2KButton}" Margin="0,30,0,0" HorizontalContentAlignment="Left" Foreground="{StaticResource PureWhiteBrush}"/>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Grid.Column="1" Background="{StaticResource MetallicGreyBrush}"/>

                        <!-- Main View Area -->
                        <Grid Grid.Column="2" Margin="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="{Binding CurrentViewTitle}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource ChromeHighlightBrush}"/>
                            
                            <Grid Grid.Row="1" Margin="0,15,0,0">
                                <!-- SYSTEM STATS VIEW -->
                                <Border BorderBrush="{StaticResource MetallicGreyBrush}" BorderThickness="1" Visibility="{Binding IsSystemViewVisible, Converter={x:Static local:Converters.BooleanToVisibilityConverter}}">
                                    <StackPanel Margin="20">
                                        <TextBlock Text="[ CPU USAGE ]" Foreground="{StaticResource ChromeHighlightBrush}" Margin="0,0,0,5"/>
                                        <Grid Height="30" Margin="0,0,0,20">
                                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding CurrentSystemStats.CpuUsagePercentage}" 
                                                         Background="{StaticResource GraphiteBrush}" Foreground="{StaticResource SoftWhiteBrush}" 
                                                         BorderBrush="{StaticResource MetallicGreyBrush}" BorderThickness="1"/>
                                            <TextBlock Text="{Binding CurrentSystemStats.CpuUsagePercentage, StringFormat={}{0}%}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PureWhiteBrush}" FontWeight="Bold"/>
                                        </Grid>

                                        <TextBlock Text="[ RAM USAGE ]" Foreground="{StaticResource ChromeHighlightBrush}" Margin="0,0,0,5"/>
                                        <Grid Height="30" Margin="0,0,0,5">
                                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding CurrentSystemStats.RamUsagePercentage}" 
                                                         Background="{StaticResource GraphiteBrush}" Foreground="{StaticResource SoftWhiteBrush}" 
                                                         BorderBrush="{StaticResource MetallicGreyBrush}" BorderThickness="1"/>
                                            <TextBlock Text="{Binding CurrentSystemStats.RamUsagePercentage, StringFormat={}{0}%}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource DeepBlackBrush}" FontWeight="Bold"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding CurrentSystemStats.UsedRamGB}" Foreground="{StaticResource PureWhiteBrush}" />
                                            <TextBlock Text=" GB / " Foreground="{StaticResource ChromeHighlightBrush}" />
                                            <TextBlock Text="{Binding CurrentSystemStats.TotalRamGB}" Foreground="{StaticResource PureWhiteBrush}" />
                                            <TextBlock Text=" GB" Foreground="{StaticResource ChromeHighlightBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- PORTS VIEW -->
                                <Border BorderBrush="{StaticResource MetallicGreyBrush}" BorderThickness="1" Visibility="{Binding IsPortsViewVisible, Converter={x:Static local:Converters.BooleanToVisibilityConverter}}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding OpenPorts}" Margin="10">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <Grid Margin="0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="60"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="100"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Protocol}" Grid.Column="0" Foreground="{StaticResource SoftWhiteBrush}"/>
                                                            <TextBlock Text="{Binding PortNumber}" Grid.Column="1" Foreground="{StaticResource PureWhiteBrush}" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding LocalAddress}" Grid.Column="2" Foreground="{StaticResource ChromeHighlightBrush}"/>
                                                            <TextBlock Grid.Column="3" Foreground="{StaticResource ChromeHighlightBrush}">
                                                                <Run Text="{Binding ProcessName}" />
                                                                <Run Text=" (PID: " />
                                                                <Run Text="{Binding ProcessId}" />
                                                                <Run Text=")" />
                                                            </TextBlock>
                                                            <Button Content="KILL" Grid.Column="4" Style="{StaticResource Y2KButton}" Padding="5" Foreground="#FF0000" Background="Transparent" BorderBrush="#FF0000"
                                                                    Command="{Binding DataContext.KillPortProcessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                        <Border BorderBrush="{StaticResource DeepBlackBrush}" BorderThickness="0,0,0,1"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <!-- DOCKER VIEW -->
                                <Border BorderBrush="{StaticResource MetallicGreyBrush}" BorderThickness="1" Visibility="{Binding IsDockerViewVisible, Converter={x:Static local:Converters.BooleanToVisibilityConverter}}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding DockerContainers}" Margin="10">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <Grid Margin="0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="200"/>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Names}" Grid.Column="0" Foreground="{StaticResource PureWhiteBrush}" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding Image}" Grid.Column="1" Foreground="{StaticResource ChromeHighlightBrush}"/>
                                                            <TextBlock Text="{Binding Status}" Grid.Column="2" Foreground="{StaticResource SoftWhiteBrush}"/>
                                                            <TextBlock Text="{Binding Ports}" Grid.Column="3" Foreground="{StaticResource ChromeHighlightBrush}" TextWrapping="WrapWithOverflow"/>
                                                        </Grid>
                                                        <Border BorderBrush="{StaticResource DeepBlackBrush}" BorderThickness="0,0,0,1"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>

                        </Grid>
                    </Grid>
                </Border>

                <!-- Footer -->
                <Grid Grid.Row="2" Background="{StaticResource GraphiteBrush}">
                    <Border BorderBrush="{StaticResource MetallicGreyBrush}" BorderThickness="0,1,0,0"/>
                    <TextBlock Text="made by biagigio" Foreground="{StaticResource ChromeHighlightBrush}" FontStyle="Italic" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="11"/>
                    <TextBlock Text="STATUS: ONLINE, SCANNING..." Foreground="#00FF00" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="11" FontFamily="Consolas"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
