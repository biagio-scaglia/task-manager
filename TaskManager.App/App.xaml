<Application x:Class="TaskManager.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        
        <SolidColorBrush x:Key="PureBlackBrush" Color="#000000"/>
        <SolidColorBrush x:Key="DeepBlackBrush" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="GraphiteBrush" Color="#1C1C1C"/>
        
        <SolidColorBrush x:Key="DarkChromeBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="MetallicGreyBrush" Color="#3A3A3A"/>
        
        <SolidColorBrush x:Key="SoftWhiteBrush" Color="#E6E6E6"/>
        <SolidColorBrush x:Key="WhiteChromeBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="PureWhiteBrush" Color="#FFFFFF"/>
        
        <SolidColorBrush x:Key="ChromeHighlightBrush" Color="#CFCFCF"/>

        <LinearGradientBrush x:Key="ChromeGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0.0" />
            <GradientStop Color="#BFBFBF" Offset="0.5" />
            <GradientStop Color="#7A7A7A" Offset="1.0" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DarkChromeGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2A2A2A" Offset="0.0" />
            <GradientStop Color="#0F0F0F" Offset="1.0" />
        </LinearGradientBrush>

        <!-- Y2K Button Style -->
        <Style x:Key="Y2KButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ChromeGradientBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DeepBlackBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource SoftWhiteBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FFFFFF" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="{StaticResource SoftWhiteBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource MetallicGreyBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PureWhiteBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Y2K Glass Panel Style -->
        <Style x:Key="Y2KGlassPanel" TargetType="Border">
            <Setter Property="Background" Value="#0CFFFFFF"/>
            <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>

        <!-- Base Text Block -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
            <Setter Property="Foreground" Value="{StaticResource PureWhiteBrush}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </Application.Resources>
</Application>
