<Application x:Class="TaskManager.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkChrome.xaml" />
            </ResourceDictionary.MergedDictionaries>

        <!-- Y2K Button Style -->
        <Style x:Key="Y2KButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ChromeGradientBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DeepBlackBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SoftWhiteBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FFFFFF" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="{DynamicResource SoftWhiteBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource MetallicGreyBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PureWhiteBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Y2K Glass Panel Style -->
        <Style x:Key="Y2KGlassPanel" TargetType="Border">
            <Setter Property="Background" Value="#0CFFFFFF"/>
            <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>

        <!-- Y2K ScrollBar RepeatButton Style (Up/Down Arrows) -->
        <Style x:Key="Y2KScrollBarButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="{DynamicResource DarkChromeGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MetallicGreyBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Y2K ScrollBar Thumb Style -->
        <Style x:Key="Y2KScrollBarThumb" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ChromeGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PureWhiteBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1,0,1,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Full Y2K ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource DeepBlackBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkChromeBrush}"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition MaxHeight="16"/>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition MaxHeight="16"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Up Button -->
                            <RepeatButton Grid.Row="0" Style="{DynamicResource Y2KScrollBarButton}" Command="ScrollBar.LineUpCommand">
                                <TextBlock Text="^" Foreground="{DynamicResource PureWhiteBrush}" FontSize="10" FontWeight="Bold" Margin="0,2,0,0"/>
                            </RepeatButton>
                            
                            <!-- Track and Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{DynamicResource Y2KScrollBarThumb}" Margin="1,0"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            
                            <!-- Down Button -->
                            <RepeatButton Grid.Row="2" Style="{DynamicResource Y2KScrollBarButton}" Command="ScrollBar.LineDownCommand">
                                <TextBlock Text="v" Foreground="{DynamicResource PureWhiteBrush}" FontSize="10" FontWeight="Bold" Margin="0,-2,0,0"/>
                            </RepeatButton>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base Text Block -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
            <Setter Property="Foreground" Value="{DynamicResource PureWhiteBrush}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
