<Application x:Class="TaskManager.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        
        <SolidColorBrush x:Key="PureBlackBrush" Color="#000000"/>
        <SolidColorBrush x:Key="DeepBlackBrush" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="GraphiteBrush" Color="#1C1C1C"/>
        
        <SolidColorBrush x:Key="DarkChromeBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="MetallicGreyBrush" Color="#3A3A3A"/>
        
        <SolidColorBrush x:Key="SoftWhiteBrush" Color="#E6E6E6"/>
        <SolidColorBrush x:Key="WhiteChromeBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="PureWhiteBrush" Color="#FFFFFF"/>
        
        <SolidColorBrush x:Key="ChromeHighlightBrush" Color="#CFCFCF"/>

        <LinearGradientBrush x:Key="ChromeGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0.0" />
            <GradientStop Color="#BFBFBF" Offset="0.5" />
            <GradientStop Color="#7A7A7A" Offset="1.0" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DarkChromeGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2A2A2A" Offset="0.0" />
            <GradientStop Color="#0F0F0F" Offset="1.0" />
        </LinearGradientBrush>

        <!-- Y2K Button Style -->
        <Style x:Key="Y2KButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ChromeGradientBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DeepBlackBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource SoftWhiteBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FFFFFF" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="{StaticResource SoftWhiteBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource MetallicGreyBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PureWhiteBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Y2K Glass Panel Style -->
        <Style x:Key="Y2KGlassPanel" TargetType="Border">
            <Setter Property="Background" Value="#0CFFFFFF"/>
            <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>

        <!-- Y2K ScrollBar RepeatButton Style (Up/Down Arrows) -->
        <Style x:Key="Y2KScrollBarButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="{StaticResource DarkChromeGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource MetallicGreyBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Y2K ScrollBar Thumb Style -->
        <Style x:Key="Y2KScrollBarThumb" TargetType="Thumb">
            <Setter Property="Background" Value="{StaticResource ChromeGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PureWhiteBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1,0,1,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Full Y2K ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource DeepBlackBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkChromeBrush}"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition MaxHeight="16"/>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition MaxHeight="16"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Up Button -->
                            <RepeatButton Grid.Row="0" Style="{StaticResource Y2KScrollBarButton}" Command="ScrollBar.LineUpCommand">
                                <TextBlock Text="^" Foreground="{StaticResource PureWhiteBrush}" FontSize="10" FontWeight="Bold" Margin="0,2,0,0"/>
                            </RepeatButton>
                            
                            <!-- Track and Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource Y2KScrollBarThumb}" Margin="1,0"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            
                            <!-- Down Button -->
                            <RepeatButton Grid.Row="2" Style="{StaticResource Y2KScrollBarButton}" Command="ScrollBar.LineDownCommand">
                                <TextBlock Text="v" Foreground="{StaticResource PureWhiteBrush}" FontSize="10" FontWeight="Bold" Margin="0,-2,0,0"/>
                            </RepeatButton>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base Text Block -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
            <Setter Property="Foreground" Value="{StaticResource PureWhiteBrush}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </Application.Resources>
</Application>
