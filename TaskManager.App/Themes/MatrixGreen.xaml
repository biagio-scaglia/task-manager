<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="PureBlackBrush" Color="#000000"/>
    <SolidColorBrush x:Key="DeepBlackBrush" Color="#050F05"/>
    <SolidColorBrush x:Key="GraphiteBrush" Color="#0A1C0A"/>
    
    <SolidColorBrush x:Key="DarkChromeBrush" Color="#102A10"/>
    <SolidColorBrush x:Key="MetallicGreyBrush" Color="#1A3A1A"/>
    
    <SolidColorBrush x:Key="SoftWhiteBrush" Color="#80FF80"/>
    <SolidColorBrush x:Key="WhiteChromeBrush" Color="#AAFFAA"/>
    <SolidColorBrush x:Key="PureWhiteBrush" Color="#00FF00"/>
    
    <SolidColorBrush x:Key="ChromeHighlightBrush" Color="#00CC00"/>

    <LinearGradientBrush x:Key="ChromeGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#00FF00" Offset="0.0" />
        <GradientStop Color="#009900" Offset="0.5" />
        <GradientStop Color="#003300" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DarkChromeGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#102A10" Offset="0.0" />
        <GradientStop Color="#050F05" Offset="1.0" />
    </LinearGradientBrush>
</ResourceDictionary>
